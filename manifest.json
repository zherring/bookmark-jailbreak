{
  "manifest_version": 3,
  "name": "Farcaster Bookmarks Exporter",
  "version": "0.2.0",
  "description": "Auto-capture and browse your Farcaster bookmarks",
  "permissions": ["activeTab", "scripting", "storage", "sidePanel", "webRequest"],
  "host_permissions": ["https://farcaster.xyz/*"],
  "action": {
    "default_title": "Farcaster Bookmarks"
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["https://farcaster.xyz/*"],
      "js": ["intercept.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://farcaster.xyz/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ],
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
