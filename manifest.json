{
  "manifest_version": 3,
  "name": "Bookmark Jailbreak",
  "version": "0.3.0",
  "version_name": "0.3.0 bookmark-jailbreak",
  "description": "Export and archive your bookmarks from Farcaster and Twitter/X",
  "permissions": ["activeTab", "scripting", "storage", "sidePanel", "webRequest"],
  "host_permissions": [
    "https://farcaster.xyz/*",
    "https://x.com/*",
    "https://twitter.com/*"
  ],
  "action": {
    "default_title": "Bookmark Jailbreak"
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["https://farcaster.xyz/*"],
      "js": ["intercept.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://farcaster.xyz/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "world": "ISOLATED"
    },
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["twitter-spike.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["twitter-content.js"],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ],
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
